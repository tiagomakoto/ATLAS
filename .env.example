# Configurações do Data Layer ADVANTAGE
# Copie este arquivo para .env e preencha as chaves API necessárias

# ── Google Gemini API ──────────────────────────────────────────────
# Obtenha uma chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Trends (opcional) ──────────────────────────────────────
# Não requer chave API, mas pode ter rate limiting
# Configure proxies se necessário:
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080

# ── Banco de Dados ───────────────────────────────────────────────
# Configurações padrão do SQLite
DB_PATH=advantage/data/alternativo.db

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=advantage/data/advantage.log

# ── Configurações de Coleta ─────────────────────────────────────
# Intervalo padrão entre coletas (em segundos)
COLLECTION_INTERVAL=3600

# ── ABPO Scraping ───────────────────────────────────────────────
# URL base para dados da Associação Brasileira de Papel e Celulose
ABPO_BASE_URL=https://abpo.org.br

# ═══════════════════════════════════════════════════════════════
# IMPORTANTE: Nunca compartilhe este arquivo com chaves reais!
# ═══════════════════════════════════════════════════════════════