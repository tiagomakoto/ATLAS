{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "nvidia/z-ai/glm-5.1",
      "temperature": 0.1,
      "top_p": 0.1,
      "max_tokens": 16384,
      "prompt": "{file:./prompts/atlas_plannerv2.txt}",
      "description": "Analisa specs e decompõe em tarefas atômicas para o BUILD. Não escreve código.",
      "maxSteps": 20,
      "permission": {
        "edit": "ask",
        "bash": "allow",
        "write": "deny"
      }
    },
    "build": {
      "mode": "primary",
      "model": "nvidia/minimaxai/minimax-m2.7",
      "temperature": 0.2,
      "top_p": 0.1,
      "prompt": "{file:./prompts/atlas-builder.txt}",
      "description": "Executa tarefas atômicas delegadas pelo PLAN. Edição cirúrgica.",
      "maxSteps": 50,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "write": "allow"
      },
      "subagents": [
        {
          "name": "fixer",
          "model": "nvidia/stepfun-ai/step-3.5-flash",
          "temperature": 0.1,
          "prompt": "{file:./prompts/atlas_fixer.txt}",
          "description": "Valida integridade estrutural, sintaxe e fechamento de blocos pós-build."
        }
      ]
    },
    "commit": {
      "mode": "primary",
      "model": "nvidia/stepfun-ai/step-3.5-flash",
      "temperature": 0.1,
      "prompt": "{file:./prompts/atlas-commit.txt}",
      "description": "Fecha o ciclo: roda update_scm.py, compõe mensagem de commit, commita código + vault e faz push.",
      "maxSteps": 15,
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "write": "deny",
        "read": "allow"
      }
    },
    "debug": {
      "mode": "primary",
      "model": "nvidia/moonshotai/kimi-k2-thinking",
      "temperature": 0.1,
      "prompt": "{file:./prompts/atlas-debugger-hotfix.txt}",
      "description": "Investiga bugs, emite diagnóstico ou aplica hotfix cirúrgico. Aciona PLAN para correções complexas.",
      "maxSteps": 30,
      "include_thinking": false,
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "write": "deny",
        "read": "allow",
        "search": "allow"
      }
    }
  }
}