# ═══════════════════════════════════════════════════════════════
# ATLAS + DELTA CHAOS — .gitignore ATUALIZADO
# ═══════════════════════════════════════════════════════════════

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
*.egg-info/

# ── Node.js / React ────────────────────────────────────────────
node_modules/
dist/
build/

# ── Dados e Cache (NÃO versionar) ─────────────────────────────
TAPE/**/*.parquet
TAPE/**/*.TXT
TAPE/**/*.ZIP
BOOK/*.json
BOOK/*.parquet
ORBIT/*.json
TradeLog/*.json
opcoes_hoje/*.xlsx
opcoes_historico/*.xlsx

# ── Arquivos Locais (fora do versionamento) ───────────────────
atlas/arquivos/
atlas/tree_structure.py
atlas/atlas_structure.txt
arquivos/
atlas/tree_structure.py
atlas/atlas_structure.txt

# ── Logs (NÃO versionar) ──────────────────────────────────────
storage/logs/
*.log
logs/
book_audit_log.json

# ── Configs Pessoais ──────────────────────────────────────────
paths.json
!paths.json.example

delta_chaos_config.json
!delta_chaos_config.json.example

# ── Master JSONs dos Ativos ───────────────────────────────────
# Se estiverem em G:\Meu Drive\... (fora do repo), ignore:
ativos/*.json
!ativos/EXAMPLE.json  # opcional: manter template

# ── IDE / OS ──────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Git ───────────────────────────────────────────────────────
.git/
!.gitignore


# ── ai-pipeline/ ───────────────────────────────────────────────────────
.env
ai-pipeline/


